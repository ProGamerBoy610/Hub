    local function updateSelectedDisplay()

        -- Clear existing tags

        for _, child in pairs(selectedContainer:GetChildren()) do

            if child:IsA("Frame") and child.Name ~= "SelectedLayout" then

                child:Destroy()

            end

        end

        

        local hasSelection = false

        local totalWidth = 0

        

        for option, selected in pairs(selectedValues) do

            if selected then

                hasSelection = true

                

                local tagFrame = Instance.new("Frame")

                tagFrame.Name = "Tag_" .. option

                tagFrame.Size = UDim2.new(0, 0, 0.7, 0) -- Dikecilkan height dari 0.8 ke 0.7

