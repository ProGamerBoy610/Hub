            optionButton.TextSize = 13 -- Dikecilkan

            optionButton.Font = FONT

            optionButton.Text = option

            optionButton.TextXAlignment = Enum.TextXAlignment.Left

            optionButton.TextYAlignment = Enum.TextYAlignment.Center

            optionButton.ZIndex = 120

            optionButton.Parent = optionsScrollFrame

            

            optionButtons[option] = optionButton

            

            local optionCorner = Instance.new("UICorner")

            optionCorner.CornerRadius = UDim.new(0, 3)

            optionCorner.Parent = optionButton

            

            local textPadding = Instance.new("UIPadding")

            textPadding.PaddingLeft = UDim.new(0, 6) -- Dikecilkan

            textPadding.Parent = optionButton

            

            local checkIcon = Instance.new("TextLabel")

            checkIcon.Name = "CheckIcon"

            checkIcon.Size = UDim2.new(0, 18, 0, 18) -- Dikecilkan

            checkIcon.Position = UDim2.new(1, -22, 0.5, -9) -- Disesuaikan posisi

            checkIcon.BackgroundTransparency = 1

            checkIcon.TextColor3 = Color3.fromRGB(255, 255, 255)

            checkIcon.TextSize = 14 -- Dikecilkan

            checkIcon.Font = FONT

            checkIcon.Text = selectedValues[option] and "✓" or ""

            checkIcon.TextYAlignment = Enum.TextYAlignment.Center

            checkIcon.ZIndex = 125

            checkIcon.Parent = optionButton

            

            optionButton.MouseEnter:Connect(function()

                if not selectedValues[option] then

                    TweenService:Create(optionButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(60, 60, 60)}):Play()

                end

            end)

            

            optionButton.MouseLeave:Connect(function()

                if not selectedValues[option] then

                    TweenService:Create(optionButton, TweenInfo.new(0.2), {BackgroundColor3 = COLORS.Frame}):Play()

                end

            end)

            

            optionButton.MouseButton1Click:Connect(function()

                selectedValues[option] = not selectedValues[option]

                checkIcon.Text = selectedValues[option] and "✓" or ""

                -- Langsung update warna tanpa animasi untuk responsivitas instant

                optionButton.BackgroundColor3 = selectedValues[option] and COLORS.Accent or COLORS.Frame

                updateSelectedDisplay()

                if callback then

                    callback(getSelectedValues())

                end

            end)

        end

    end

    

    -- Select All button functionality

    selectAllButton.MouseButton1Click:Connect(function()

        for _, option in ipairs(options) do

            selectedValues[option] = true

            if optionButtons[option] then

                optionButtons[option].BackgroundColor3 = COLORS.Accent

                local checkIcon = optionButtons[option]:FindFirstChild("CheckIcon")

                if checkIcon then

                    checkIcon.Text = "✓"

                end

            end

        end

        updateSelectedDisplay()

        if callback then

            callback(getSelectedValues())

        end

    end)

    

    -- Clear All button functionality

    clearAllButton.MouseButton1Click:Connect(function()

        for option, _ in pairs(selectedValues) do

            selectedValues[option] = false

            if optionButtons[option] then

                optionButtons[option].BackgroundColor3 = COLORS.Frame

                local checkIcon = optionButtons[option]:FindFirstChild("CheckIcon")

                if checkIcon then

                    checkIcon.Text = ""

                end

            end

        end

        updateSelectedDisplay()

        if callback then

            callback(getSelectedValues())

        end

    end)

    

    -- Button hover effects

    selectAllButton.MouseEnter:Connect(function()

        TweenService:Create(selectAllButton, TweenInfo.new(0.2), {BackgroundColor3 = COLORS.Accent}):Play()

    end)

    

    selectAllButton.MouseLeave:Connect(function()

        TweenService:Create(selectAllButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(50, 50, 50)}):Play()

    end)

    

    clearAllButton.MouseEnter:Connect(function()

        TweenService:Create(clearAllButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(200, 50, 50)}):Play()

    end)

    

    clearAllButton.MouseLeave:Connect(function()

        TweenService:Create(clearAllButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(50, 50, 50)}):Play()

    end)

    

    dropdownButton.MouseButton1Click:Connect(function()

        isOpen = not isOpen

        if isOpen then

            createOptions()

            arrowIcon.Text = "▲"

            menuContainer.Visible = true

            local visibleOptionsHeight = math.min(#options, maxVisibleOptions) * (optionHeight + 1) + 25 -- Disesuaikan

            TweenService:Create(menuContainer, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, visibleOptionsHeight)}):Play()

        else

            arrowIcon.Text = "▼"

            TweenService:Create(menuContainer, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Size = UDim2.new(1, 0, 0, 0)}):Play()

            wait(0.2)

            menuContainer.Visible = false

        end

    end)

    

    -- Initialize display

    updateSelectedDisplay()

    

    return dropdownContainer, {

        getValue = function() 

            return getSelectedValues() 

        end,

        setValue = function(values)

            -- Clear existing selections

            for option, _ in pairs(selectedValues) do

                selectedValues[option] = false

            end

            

            -- Set new selections

            if type(values) == "table" then

                for _, value in ipairs(values) do

                    local found = false

                    for _, option in ipairs(options) do

                        if option == value then

                            found = true

                            selectedValues[value] = true

                            break

                        end

                    end

                    if not found then

                        warn("MultiSelect setValue: Value '" .. tostring(value) .. "' not found in options")

                    end

                end

            else

                warn("MultiSelect setValue: Expected table, got " .. type(values))

                return

            end

            

            updateSelectedDisplay()

            if callback then

                callback(getSelectedValues())

            end

        end,

        setOptions = function(newOptions, newDefaults)

            options = newOptions

            selectedValues = {}

            

            if newDefaults and type(newDefaults) == "table" then

                for _, value in ipairs(newDefaults) do

                    selectedValues[value] = true

                end

            end

            

            updateSelectedDisplay()

            if isOpen then

                createOptions()

            end

            if callback then

                callback(getSelectedValues())

            end

        end,

        selectAll = function()

            for _, option in ipairs(options) do

                selectedValues[option] = true

            end

            updateSelectedDisplay()

            if callback then

                callback(getSelectedValues())

            end

        end,

        clearAll = function()

            for option, _ in pairs(selectedValues) do

                selectedValues[option] = false

            end

            updateSelectedDisplay()

            if callback then

                callback(getSelectedValues())

            end

        end

    }

end

