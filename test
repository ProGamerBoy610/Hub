                tagCorner.Parent = tagFrame

                

                local tagText = Instance.new("TextLabel")

                tagText.Name = "TagText"

                tagText.Size = UDim2.new(1, -20, 1, 0)

                tagText.Position = UDim2.new(0, 4, 0, 0)

                tagText.BackgroundTransparency = 1

                tagText.TextColor3 = Color3.fromRGB(255, 255, 255)

                tagText.TextSize = 12

                tagText.Font = FONT

                tagText.Text = option

                tagText.TextXAlignment = Enum.TextXAlignment.Left

                tagText.TextTruncate = Enum.TextTruncate.AtEnd

                tagText.Parent = tagFrame

                

                local removeButton = Instance.new("TextButton")

                removeButton.Name = "RemoveButton"

                removeButton.Size = UDim2.new(0, 16, 0, 16)

                removeButton.Position = UDim2.new(1, -18, 0.5, -8)

                removeButton.BackgroundTransparency = 1

                removeButton.TextColor3 = Color3.fromRGB(255, 255, 255)

                removeButton.TextSize = 14

                removeButton.Font = FONT

                removeButton.Text = "×"

                removeButton.Parent = tagFrame

                

                -- Calculate tag width

                local textService = game:GetService("TextService")

                local textSize = textService:GetTextSize(option, 12, FONT, Vector2.new(math.huge, 20))

                local tagWidth = math.min(textSize.X + 28, 80) -- Dikecilkan max width

                tagFrame.Size = UDim2.new(0, tagWidth, 0.7, 0) -- Ubah height ke 0.7

                totalWidth = totalWidth + tagWidth + 4

                

                removeButton.MouseButton1Click:Connect(function()

                    selectedValues[option] = false

                    updateSelectedDisplay()

                    if optionButtons[option] then

                        optionButtons[option].BackgroundColor3 = COLORS.Frame

                        local checkIcon = optionButtons[option]:FindFirstChild("CheckIcon")

                        if checkIcon then

                            checkIcon.Text = ""

                        end

                    end

                    if callback then

                        callback(getSelectedValues())

                    end

                end)

            end

        end

        

        selectedContainer.CanvasSize = UDim2.new(0, totalWidth, 0, 0)

        placeholderText.Visible = not hasSelection

    end

    

    local function getSelectedValues()

        local result = {}

        for option, selected in pairs(selectedValues) do

            if selected then

                table.insert(result, option)

            end

        end

        return result

    end

    

    local function createOptions()

        for _, child in pairs(optionsScrollFrame:GetChildren()) do

            if child:IsA("TextButton") then

                child:Destroy()

            end

        end

        

        optionButtons = {}

        local totalOptionsHeight = #options * (optionHeight + 1) -- Padding dikurangi

        optionsScrollFrame.CanvasSize = UDim2.new(0, 0, 0, totalOptionsHeight)

        

        for i, option in ipairs(options) do

            local optionButton = Instance.new("TextButton")

            optionButton.Name = "Option_" .. option

            optionButton.Size = UDim2.new(1, -8, 0, optionHeight)

            optionButton.Position = UDim2.new(0, 4, 0, (i-1) * (optionHeight + 1))

