        -- Animate button appearing
        OpenButton.Size = UDim2.new(0, 0, 0, 0)
        OpenButton.BackgroundTransparency = 1
        OpenButton.TextTransparency = 1
        OpenStroke.Transparency = 1
        Shadow.ImageTransparency = 1
        
        TweenService:Create(OpenButton, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 160, 0, 45),
            BackgroundTransparency = 0,
            TextTransparency = 0
        }):Play()
        
        TweenService:Create(OpenStroke, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Transparency = 0.3
        }):Play()
        
        TweenService:Create(Shadow, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            ImageTransparency = 0.7
        }):Play()
        
        -- Hover effects
        OpenButton.MouseEnter:Connect(function()
            TweenService:Create(OpenButton, TweenInfo.new(0.2), {
                Size = UDim2.new(0, 170, 0, 48)
            }):Play()
            TweenService:Create(OpenStroke, TweenInfo.new(0.2), {
                Color = Color3.fromRGB(150, 170, 255),
                Transparency = 0
            }):Play()
            TweenService:Create(Shadow, TweenInfo.new(0.2), {
                ImageTransparency = 0.5
            }):Play()
        end)
        
        OpenButton.MouseLeave:Connect(function()
            TweenService:Create(OpenButton, TweenInfo.new(0.2), {
                Size = UDim2.new(0, 160, 0, 45)
            }):Play()
            TweenService:Create(OpenStroke, TweenInfo.new(0.2), {
                Color = Color3.fromRGB(114, 137, 218),
                Transparency = 0.3
            }):Play()
            TweenService:Create(Shadow, TweenInfo.new(0.2), {
                ImageTransparency = 0.7
            }):Play()
        end)
        
        -- ========================================
        -- DRAGGING FOR MOBILE + PC
        -- ========================================
        local dragging = false
        local dragInput
        local dragStart
        local startPos
        
        -- PC Dragging
        OpenButton.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = OpenButton.Position
                
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                        -- Save the position when dragging ends
                        savedOpenButtonPosition = OpenButton.Position
                    end
                end)
            end
        end)
        
        OpenButton.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                dragInput = input
            end
        end)
        
        UIS.InputChanged:Connect(function(input)
            if input == dragInput and dragging then
                local delta = input.Position - dragStart
                OpenButton.Position = UDim2.new(
                    startPos.X.Scale,
                    startPos.X.Offset + delta.X,
                    startPos.Y.Scale,
                    startPos.Y.Offset + delta.Y
                )
            end
        end)
        
        -- Mobile Touch Dragging
        if UIS.TouchEnabled then
            local touchConnection
            local touchEndedConnection
            
            OpenButton.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    dragStart = input.Position
                    startPos = OpenButton.Position
                    
                    touchConnection = UIS.TouchMoved:Connect(function(touchInput)
                        if dragging then
                            local delta = touchInput.Position - dragStart
                            OpenButton.Position = UDim2.new(
                                startPos.X.Scale,
                                startPos.X.Offset + delta.X,
                                startPos.Y.Scale,
                                startPos.Y.Offset + delta.Y
                            )
                        end
                    end)
                    
                    touchEndedConnection = UIS.TouchEnded:Connect(function(touchInput)
                        if touchInput == input then
                            dragging = false
                            savedOpenButtonPosition = OpenButton.Position
                            if touchConnection then touchConnection:Disconnect() end
                            if touchEndedConnection then touchEndedConnection:Disconnect() end
                        end
                    end)
                end
            end)
        end
        
        -- Click to open GUI
        local clickStartPos
        OpenButton.MouseButton1Down:Connect(function()
            clickStartPos = OpenButton.Position
        end)
        
        OpenButton.MouseButton1Click:Connect(function()
            -- Only open if button wasn't dragged (position didn't change much)
            local currentPos = OpenButton.Position
            if clickStartPos and 
               math.abs(currentPos.X.Offset - clickStartPos.X.Offset) < 5 and 
               math.abs(currentPos.Y.Offset - clickStartPos.Y.Offset) < 5 then
                
                -- Animate button disappearing
                TweenService:Create(OpenButton, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                    Size = UDim2.new(0, 0, 0, 0),
                    BackgroundTransparency = 1,
                    TextTransparency = 1
                }):Play()
                
                TweenService:Create(OpenStroke, TweenInfo.new(0.3), {
                    Transparency = 1
                }):Play()
                
                TweenService:Create(Shadow, TweenInfo.new(0.3), {
                    ImageTransparency = 1
                }):Play()
                
                wait(0.3)
                -- DON'T destroy the GUI, just hide it so position is saved
                OpenButtonGui.Enabled = false
                
                -- Reset MainFrame to original state
                MainFrame.BackgroundTransparency = 0
                MainFrame.Size = UDim2.new(0, 450, 0, 335)
                MainFrame.Position = UDim2.new(0.5, -216, 0.5, -180)
                MainFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                
                TopBar.BackgroundTransparency = 0
                TopBar.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                
                ScrollingFrame.BackgroundTransparency = 1
                ScrollingFrame.ScrollBarImageColor3 = Color3.fromRGB(10, 10, 10)
                
                Title.TextTransparency = 0
                Title.TextColor3 = Color3.fromRGB(255, 255, 255)
                
                for _, child in pairs(MainFrame:GetChildren()) do
                    if child:IsA("GuiObject") and child ~= ScrollingFrame then
                        if child.Name ~= "UICorner" and child.Name ~= "MainFrameBorder" then
                            child.BackgroundTransparency = 0
                            
                            if child:IsA("TextLabel") or child:IsA("TextButton") then
                                child.TextTransparency = 0
                            end
                        end
                    end
                end
                
                CloseButton.BackgroundTransparency = 0
                CloseButton.TextTransparency = 0
                CloseButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                
                MinimizeButton.BackgroundTransparency = 0
                MinimizeButton.TextTransparency = 0
                MinimizeButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                
                CopyrightButton.BackgroundTransparency = 0
                CopyrightButton.TextTransparency = 0
                CopyrightButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                
                -- Re-enable the GUI with animation
                ScreenGui.Enabled = true
                
                MainFrame.Size = UDim2.new(0, 0, 0, 0)
                MainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
                
                TweenService:Create(MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                    Size = UDim2.new(0, 450, 0, 335),
                    Position = UDim2.new(0.5, -216, 0.5, -180)
                }):Play()
            end
        end)
    end)
end)

return ModernGUILibraryFE
